<Window x:Class="S7Explorer.SymbolManagerWindow"
        PreviewKeyDown="Window_PreviewKeyDown"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        mc:Ignorable="d"
        Title="Symbol Manager" Height="650" Width="1200"
        WindowStartupLocation="CenterScreen"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:TitleBar.ExtendViewIntoTitleBar="True"
        ui:TitleBar.IsBackButtonVisible="False"
        Style="{DynamicResource {x:Type Window}}">
    <Window.Resources>
        <Style x:Key="HeaderFilterButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="{DynamicResource SystemControlPageBackgroundChromeLowBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="HeaderFilterTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Height" Value="22"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Background" Value="{DynamicResource SystemControlPageBackgroundChromeLowBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        </Style>
    </Window.Resources>
    <Grid Margin="15,47,15,15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="367*"/>
            <ColumnDefinition Width="218*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Ba�l�k -->
        <TextBlock x:Name="LblSymbolMgrHeader" Grid.Row="0" Text="Symbolic Address Definitions" 
                   FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15" Grid.ColumnSpan="2"
                   TextTrimming="CharacterEllipsis"
                   ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>

        <!-- Arama ve Filtreleme -->
        <Border Grid.Row="1"
                WindowChrome.IsHitTestVisibleInChrome="True"
                Background="{DynamicResource SystemControlPageBackgroundChromeLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,10" Grid.ColumnSpan="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                        <ui:FontIcon Glyph="&#xE721;" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock x:Name="LblSearch" Text="Search:" VerticalAlignment="Center" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                    </StackPanel>

                    <TextBox Grid.Column="1" x:Name="TxtSearch"
                             VerticalContentAlignment="Center"
                             Height="32"
                             TextChanged="TxtSearch_TextChanged"
                             ui:ControlHelper.PlaceholderText="Search in all columns..."/>

                    <TextBlock Grid.Column="2" x:Name="TxtFilterSummary" VerticalAlignment="Center" Margin="12,0,12,0"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>

                    <Button Grid.Column="3" x:Name="BtnResetSort" MinWidth="140" Height="32"
                            Margin="0,0,10,0" Click="BtnResetSort_Click">
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Glyph="&#xE72C;" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock x:Name="TxtBtnResetSort" Text="Original Order" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="4" x:Name="BtnClearFilters" MinWidth="150" Height="32"
                            Margin="0,0,10,0" Click="BtnClearFilters_Click">
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Glyph="&#xE894;" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock x:Name="TxtBtnClearFilters" Text="Clear Filters" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="5" x:Name="BtnSelectAll" MinWidth="140" Height="32"
                            Margin="0,0,10,0" Click="BtnSelectAll_Click"
                            ToolTip="Select all records (Ctrl+A)">
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Glyph="&#xE762;" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock x:Name="TxtBtnSelectAll" Text="Select All" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="6" x:Name="BtnDeleteSelected" MinWidth="150" Height="32"
                            Click="BtnDeleteSelected_Click">
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Glyph="&#xE74D;" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock x:Name="TxtBtnDeleteSelected" Text="Delete Selected" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <Grid Grid.Row="1" Margin="0,10,0,0">
                    <TextBlock x:Name="TxtFilterHint" VerticalAlignment="Center"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               Text="Column filters are available from header arrows."/>
                </Grid>
            </Grid>
        </Border>

        <!-- Sembol Listesi -->
        <DataGrid Grid.Row="2" x:Name="DgSymbols"
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False"
                  CanUserDeleteRows="True"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  HeadersVisibility="Column"
                  Margin="0,0,0,10" Grid.ColumnSpan="2">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="Padding" Value="8,4"/>
                    <Setter Property="MinHeight" Value="36"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="Background" Value="{DynamicResource SystemControlPageBackgroundChromeLowBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding SymbolicName}" Width="2*">
                    <DataGridTextColumn.Header>
                        <StackPanel Margin="0">
                            <Grid Margin="0,0,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" x:Name="ColHdrSymbolicName" Text="Symbolic Name" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <Button x:Name="BtnFilterSymbolicName" Grid.Column="1" Margin="4,0,0,0" Style="{StaticResource HeaderFilterButtonStyle}"
                                        Click="HeaderFilterToggle_Click" Tag="TxtFilterSymbolicName">
                                    <ui:FontIcon Glyph="&#xE70D;" FontSize="10"/>
                                </Button>
                            </Grid>
                            <TextBox x:Name="TxtFilterSymbolicName"
                                     Visibility="Collapsed"
                                     Style="{StaticResource HeaderFilterTextBoxStyle}"
                                     Margin="0"
                                     VerticalContentAlignment="Center"
                                     TextChanged="ColumnFilter_TextChanged"
                                     Tag="SymbolicName"/>
                        </StackPanel>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>

                <DataGridTextColumn Binding="{Binding PhysicalAddress}" Width="*">
                    <DataGridTextColumn.Header>
                        <StackPanel Margin="0">
                            <Grid Margin="0,0,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" x:Name="ColHdrPhysicalAddress" Text="Physical Address" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <Button x:Name="BtnFilterPhysicalAddress" Grid.Column="1" Margin="4,0,0,0" Style="{StaticResource HeaderFilterButtonStyle}"
                                        Click="HeaderFilterToggle_Click" Tag="TxtFilterPhysicalAddress">
                                    <ui:FontIcon Glyph="&#xE70D;" FontSize="10"/>
                                </Button>
                            </Grid>
                            <TextBox x:Name="TxtFilterPhysicalAddress"
                                     Visibility="Collapsed"
                                     Style="{StaticResource HeaderFilterTextBoxStyle}"
                                     Margin="0"
                                     VerticalContentAlignment="Center"
                                     TextChanged="ColumnFilter_TextChanged"
                                     Tag="PhysicalAddress"/>
                        </StackPanel>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>

                <DataGridTextColumn Binding="{Binding DataType}" Width="0.8*">
                    <DataGridTextColumn.Header>
                        <StackPanel Margin="0">
                            <Grid Margin="0,0,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" x:Name="ColHdrDataType" Text="Type" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <Button x:Name="BtnFilterDataType" Grid.Column="1" Margin="4,0,0,0" Style="{StaticResource HeaderFilterButtonStyle}"
                                        Click="HeaderFilterToggle_Click" Tag="TxtFilterDataType">
                                    <ui:FontIcon Glyph="&#xE70D;" FontSize="10"/>
                                </Button>
                            </Grid>
                            <TextBox x:Name="TxtFilterDataType"
                                     Visibility="Collapsed"
                                     Style="{StaticResource HeaderFilterTextBoxStyle}"
                                     Margin="0"
                                     VerticalContentAlignment="Center"
                                     TextChanged="ColumnFilter_TextChanged"
                                     Tag="DataType"/>
                        </StackPanel>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>

                <DataGridTextColumn Binding="{Binding DefaultValue}" Width="1*">
                    <DataGridTextColumn.Header>
                        <StackPanel Margin="0">
                            <Grid Margin="0,0,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" x:Name="ColHdrDefaultValue" Text="Default Value" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <Button x:Name="BtnFilterDefaultValue" Grid.Column="1" Margin="4,0,0,0" Style="{StaticResource HeaderFilterButtonStyle}"
                                        Click="HeaderFilterToggle_Click" Tag="TxtFilterDefaultValue">
                                    <ui:FontIcon Glyph="&#xE70D;" FontSize="10"/>
                                </Button>
                            </Grid>
                            <TextBox x:Name="TxtFilterDefaultValue"
                                     Visibility="Collapsed"
                                     Style="{StaticResource HeaderFilterTextBoxStyle}"
                                     Margin="0"
                                     VerticalContentAlignment="Center"
                                     TextChanged="ColumnFilter_TextChanged"
                                     Tag="DefaultValue"/>
                        </StackPanel>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>

                <DataGridTextColumn Binding="{Binding Description}" Width="1.5*">
                    <DataGridTextColumn.Header>
                        <StackPanel Margin="0">
                            <Grid Margin="0,0,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" x:Name="ColHdrDescription" Text="Description" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <Button x:Name="BtnFilterDescription" Grid.Column="1" Margin="4,0,0,0" Style="{StaticResource HeaderFilterButtonStyle}"
                                        Click="HeaderFilterToggle_Click" Tag="TxtFilterDescription">
                                    <ui:FontIcon Glyph="&#xE70D;" FontSize="10"/>
                                </Button>
                            </Grid>
                            <TextBox x:Name="TxtFilterDescription"
                                     Visibility="Collapsed"
                                     Style="{StaticResource HeaderFilterTextBoxStyle}"
                                     Margin="0"
                                     VerticalContentAlignment="Center"
                                     TextChanged="ColumnFilter_TextChanged"
                                     Tag="Description"/>
                        </StackPanel>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Alt B�l�m: Dosya ��lemleri ve Butonlar -->
        <Border Grid.Row="3"
                Background="{DynamicResource SystemControlPageBackgroundChromeLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1" CornerRadius="4" Padding="15" Grid.ColumnSpan="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource SystemControlPageBackgroundAltMediumBrush}"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.4*"/>
                            <ColumnDefinition Width="1.4*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1.8*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" x:Name="TxtNewSymbolicName" Height="32" Margin="0,0,8,0"
                                 VerticalContentAlignment="Center"
                                 ui:ControlHelper.PlaceholderText="Symbolic name (required)"/>
                        <TextBox Grid.Column="1" x:Name="TxtNewPhysicalAddress" Height="32" Margin="0,0,8,0"
                                 VerticalContentAlignment="Center"
                                 ui:ControlHelper.PlaceholderText="Physical address (required)"/>
                        <ComboBox Grid.Column="2" x:Name="TxtNewDataType" Height="32" Margin="0,0,8,0"
                                  IsEditable="True"
                                  IsTextSearchEnabled="True"
                                  StaysOpenOnEdit="True"
                                  SelectionChanged="TxtNewDataType_SelectionChanged"
                                  LostFocus="TxtNewDataType_LostFocus"
                                  HorizontalAlignment="Stretch"
                                  VerticalContentAlignment="Center"
                                  ui:ControlHelper.PlaceholderText="Type">
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">BOOL</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">BYTE</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">WORD</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">DWORD</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">LWORD</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">SINT</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">USINT</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">INT</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">UINT</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">DINT</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">UDINT</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">LINT</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">ULINT</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">REAL</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">LREAL</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">CHAR</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">WCHAR</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">STRING[254]</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">WSTRING[254]</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">TIME</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">DATE</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">TIME_OF_DAY</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">DATE_AND_TIME</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">DTL</sys:String>
                        </ComboBox>
                        <TextBox Grid.Column="3" x:Name="TxtNewDefaultValue" Height="32" Margin="0,0,8,0"
                                 VerticalContentAlignment="Center"
                                 ui:ControlHelper.PlaceholderText="Default"/>
                        <TextBox Grid.Column="4" x:Name="TxtNewDescription" Height="32" Margin="0,0,10,0"
                                 VerticalContentAlignment="Center"
                                 ui:ControlHelper.PlaceholderText="Description"/>

                        <Button Grid.Column="5" x:Name="BtnAddManualSymbol" MinWidth="160" Height="32"
                                Click="BtnAddManualSymbol_Click" Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon Glyph="&#xE710;" FontSize="14" Margin="0,0,6,0"/>
                                <TextBlock Text="Add Symbol" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Dosya ��lemleri -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="LblFileOps" Text="File Operations" FontWeight="SemiBold" 
                               VerticalAlignment="Center" Margin="0,0,15,0"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>

                    <Button x:Name="BtnParseDb" MinWidth="130" Height="34" Margin="0,0,10,0"
                            Click="BtnParseDb_Click">
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Glyph="&#xE8A5;" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock x:Name="TxtBtnParseDb" Text="DB Parse" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnLoadCsv" MinWidth="130" Height="34" Margin="0,0,10,0"
                            Click="BtnLoadCsv_Click">
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Glyph="&#xE8E5;" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock x:Name="TxtBtnLoadCsv" Text="Load JSON" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnSaveCsv" MinWidth="170" Height="34" Margin="0,0,10,0"
                            Click="BtnSaveCsv_Click">
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Glyph="&#xE74E;" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock x:Name="TxtBtnSaveCsv" Text="Save JSON As" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Border Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}"
                            BorderBrush="{DynamicResource SystemControlHighlightAccentBrush}"
                            BorderThickness="1" CornerRadius="4" Padding="8,5" Margin="10,0,0,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:FontIcon Glyph="&#xE946;" FontSize="12" Margin="0,0,4,0"/>
                            <TextBlock x:Name="LblMainFilePrefix" Text="Main file: " VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                            <TextBlock Text="symbols.json" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Kaydet/�ptal Butonlar -->
                <ui:SimpleStackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10"
                                    VerticalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="34"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="BtnSave" Grid.Column="0" MinWidth="150" Height="36"
                                Click="BtnSave_Click"
                                IsDefault="True"
                                Style="{StaticResource AccentButtonStyle}"
                                Margin="0,0,2,0">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon Glyph="&#xE74E;" FontSize="14" Margin="0,0,6,0"/>
                                <TextBlock x:Name="TxtBtnSave" Text="Save" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="BtnSaveOptions" Grid.Column="1" Height="36"
                                Click="BtnSaveOptions_Click"
                                Style="{StaticResource SplitAccentChevronButtonStyle}">
                            <ui:FontIcon Glyph="&#xE70D;" FontSize="10"/>
                            <Button.ContextMenu>
                                <ContextMenu x:Name="SaveContextMenu">
                                    <MenuItem x:Name="MiSave" Click="MiSave_Click">
                                        <MenuItem.Icon>
                                            <ui:FontIcon Glyph="&#xE74E;" FontSize="12"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem x:Name="MiSaveAndClose" Click="MiSaveAndClose_Click">
                                        <MenuItem.Icon>
                                            <ui:FontIcon Glyph="&#xE711;" FontSize="12"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </Grid>

                    <Button x:Name="BtnCancel" MinWidth="90" Height="36" 
                            Click="BtnCancel_Click"
                            IsCancel="True">
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Glyph="&#xE711;" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock x:Name="TxtBtnCancel" Text="Cancel" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </ui:SimpleStackPanel>
                </Grid>
            </Grid>
        </Border>
        <!-- Ba�l�k �ubu�u: Dil se�me butonu -->
                <Button x:Name="BtnToggleLanguage"
                    VerticalAlignment="Top" HorizontalAlignment="Right"
                    Margin="0,-47,165,0"
                    Width="36" Height="32"
                    Click="BtnToggleLanguage_Click"
                     ToolTip="Select language"
                    WindowChrome.IsHitTestVisibleInChrome="True"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0" Grid.Column="1">
            <ui:FontIcon Glyph="&#xE909;" FontSize="16"/>
        </Button>

        <!-- Ba�l�k �ubu�u: Tema de�i�tirme butonu -->
        <Button x:Name="BtnToggleTheme"
                    VerticalAlignment="Top" HorizontalAlignment="Right"
                    Margin="0,-47,123,0"
                    Width="36" Height="32"
                    Click="BtnToggleTheme_Click"
                    ToolTip="Select theme"
                    WindowChrome.IsHitTestVisibleInChrome="True"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0" Grid.Column="1">
            <Button.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="☀  Light"       Tag="Light"      IsCheckable="True" Click="ThemeMenuItem_Click"/>
                    <MenuItem Header="🌙  Dark"        Tag="Dark"       IsCheckable="True" Click="ThemeMenuItem_Click"/>
                    <MenuItem Header="🔧  Industrial"  Tag="Industrial" IsCheckable="True" Click="ThemeMenuItem_Click"/>
                    <MenuItem Header="🌌  Night"       Tag="Night"      IsCheckable="True" Click="ThemeMenuItem_Click"/>
                </ContextMenu>
            </Button.ContextMenu>
            <ui:FontIcon Glyph="&#xE771;" FontSize="16"/>
        </Button>
    </Grid>
</Window>
